# Neo4j HA - 环境变量配置
# 复制为 .env 后修改: cp .env.example .env

# ========== 密码（部署前必须修改） ==========
NEO4J_PASSWORD=CHANGE_ME_neo4j_password
ADMIN_TOKEN=CHANGE_ME_admin_token

# ========== 外部 Redis（复用平台已有实例） ==========
REDIS_HOST=172.19.0.11
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ========== HA Agent 镜像（测试环境用仓库镜像时设置；默认 neo4j-ha-agent:1.0.0-SNAPSHOT） ==========
# HA_AGENT_IMAGE=registry.example.com/neo4j-ha-agent:1.0.0-SNAPSHOT
# 仅使用已推送镜像、不合并 test-compose.dev.yml 时：USE_HA_AGENT_BUILD_OVERLAY=0
# USE_HA_AGENT_BUILD_OVERLAY=0

# ========== Neo4j 内存 (单机双实例时建议减半) ==========
NEO4J_HEAP=4G
NEO4J_PAGECACHE=2G

# ========== 时区 ==========
TZ=Asia/Singapore
